<Window x:Class="WpfApp5.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Моделювання взаємоблокувань і алгоритму банкіра"
        WindowState="Maximized"
        MinWidth="1180"
        MinHeight="760"
        Background="#1E1E2E"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#4C9BE8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#5AABF8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#3A8BD8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#3A3A52"/>
                                <Setter Property="Foreground" Value="#666680"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#4CAF7D"/>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#E85C5C"/>
        </Style>

        <Style x:Key="MutedButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#45475A"/>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#CDD6F4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#4C9BE8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SpinnerTextBox" TargetType="TextBox" BasedOn="{StaticResource ModernTextBox}">
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A6ADC8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#45475A"/>
            <Setter Property="VerticalGridLinesBrush" Value="#45475A"/>
            <Setter Property="HeadersVisibility" Value="All"/>
            <Setter Property="RowHeaderWidth" Value="42"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#A6ADC8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGridRowHeader">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#A6ADC8"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="6,0"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#313244" CornerRadius="10" Padding="20,14" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Моделювання і усунення взаємоблокувань та голодування"
                               Foreground="#CDD6F4" FontSize="20" FontWeight="Bold"/>
                    <TextBlock Text="Лабораторна робота №5 | Моделювання алгоритму банкіра"
                               Foreground="#6C7086" FontSize="12" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="✓ Аналіз" Style="{StaticResource ModernButton}" Margin="0,0,8,0"
                            Click="AnalyzeButton_Click"/>
                    <Button Content="🗑 Очистити лог" Style="{StaticResource MutedButton}"
                            Click="ClearLogButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="⚙ Параметри системи" Style="{StaticResource SectionHeader}"/>

                            <TextBlock Text="Кількість процесів P:" Style="{StaticResource FieldLabel}"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="34"/>
                                    <ColumnDefinition Width="34"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="ProcessCountText" Grid.Column="0" Text="4"
                                         Style="{StaticResource SpinnerTextBox}"
                                         PreviewTextInput="NumericOnly_PreviewTextInput"/>
                                <Button Grid.Column="1" Content="▲" Height="17" Padding="0" Margin="4,0,0,2"
                                        Style="{StaticResource ModernButton}" Click="ProcessUp_Click"/>
                                <Button Grid.Column="2" Content="▼" Height="17" Padding="0" Margin="4,2,0,0"
                                        Style="{StaticResource ModernButton}" Click="ProcessDown_Click"/>
                            </Grid>

                            <TextBlock Text="Кількість типів ресурсів R:" Style="{StaticResource FieldLabel}"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="34"/>
                                    <ColumnDefinition Width="34"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="ResourceCountText" Grid.Column="0" Text="3"
                                         Style="{StaticResource SpinnerTextBox}"
                                         PreviewTextInput="NumericOnly_PreviewTextInput"/>
                                <Button Grid.Column="1" Content="▲" Height="17" Padding="0" Margin="4,0,0,2"
                                        Style="{StaticResource ModernButton}" Click="ResourceUp_Click"/>
                                <Button Grid.Column="2" Content="▼" Height="17" Padding="0" Margin="4,2,0,0"
                                        Style="{StaticResource ModernButton}" Click="ResourceDown_Click"/>
                            </Grid>

                            <TextBlock Text="Загальна кількість ресурсів E:" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TotalsText" Text="8 10 9" Style="{StaticResource ModernTextBox}"
                                     Margin="0,0,0,10"/>

                            <Button Content="Згенерувати параметри" Margin="0,10,0,0"
                                    Style="{StaticResource ModernButton}"
                                    Click="PresetAdvanced_Click"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="StatusPanel" Style="{StaticResource Card}" Background="#1E3A1E">
                        <StackPanel>
                            <TextBlock x:Name="StatusText" Text="⬤ Готово до моделювання"
                                       Foreground="#A6E3A1" FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock x:Name="StatusDetailText"
                                       Text="Згенеруйте матриці або змініть клітинки вручну та натисніть «Аналіз»."
                                       Foreground="#A6ADC8" FontSize="11" Margin="0,4,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="🧮 Вектори" Style="{StaticResource SectionHeader}"/>
                            <TextBlock x:Name="TotalsView" Text="E = [8, 10, 9]" Foreground="#CDD6F4" FontFamily="Consolas"/>
                            <TextBlock x:Name="AvailableView" Text="A = [0, 0, 0]" Foreground="#A6E3A1"
                                       FontFamily="Consolas" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="📨 Запит ресурсів" Style="{StaticResource SectionHeader}"/>

                            <TextBlock Text="Процес Pi (номер):" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="RequestPidText" Text="0"
                 Style="{StaticResource ModernTextBox}"
                 Margin="0,0,0,10"
                 PreviewTextInput="NumericOnly_PreviewTextInput"/>

                            <TextBlock Text="Запит (через пробіл, напр. 1 0 2):"
                   Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="RequestVectorText" Text="0 0 0"
                 Style="{StaticResource ModernTextBox}"
                 Margin="0,0,0,10"/>

                            <Button Content="Виконати запит"
                Style="{StaticResource ModernButton}"
                Click="ResourceRequestButton_Click"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <GridSplitter Grid.Column="1" Width="12" HorizontalAlignment="Stretch"
                          Background="#313244" VerticalAlignment="Stretch"/>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Виділено C" Style="{StaticResource SectionHeader}"/>
                            <DataGrid x:Name="AllocationGrid" Height="190"
                                      LoadingRow="MatrixGrid_LoadingRow"
                                      CellEditEnding="MatrixGrid_CellEditEnding"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Максимум Max" Style="{StaticResource SectionHeader}"/>
                            <DataGrid x:Name="MaxGrid" Height="190"
                                      LoadingRow="MatrixGrid_LoadingRow"
                                      CellEditEnding="MatrixGrid_CellEditEnding"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="4" Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Потреби Need = Max - C" Style="{StaticResource SectionHeader}"/>
                            <DataGrid x:Name="NeedGrid" Height="190" IsReadOnly="True"
                                      LoadingRow="MatrixGrid_LoadingRow"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Grid.Row="1" Background="#2A2A3E" CornerRadius="10" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="📋 Лог моделювання" Style="{StaticResource SectionHeader}"/>
                        <RichTextBox x:Name="LogBox" Grid.Row="1"
                                     Background="#1E1E2E"
                                     Foreground="#CDD6F4"
                                     FontFamily="Consolas, Courier New"
                                     FontSize="12"
                                     IsReadOnly="True"
                                     BorderThickness="0"
                                     Padding="12"
                                     VerticalScrollBarVisibility="Auto"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
